<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pos.controllers.CustomerController">
    <children>
        <TableView fx:id="table" AnchorPane.topAnchor="12" AnchorPane.bottomAnchor="12" AnchorPane.leftAnchor="12" AnchorPane.rightAnchor="12">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                <TableColumn fx:id="nameColumn" text="Full Name" prefWidth="220"/>
                <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="170"/>
                <TableColumn fx:id="emailColumn" text="Email" prefWidth="240"/>
            </columns>
        </TableView>
    </children>
</AnchorPane>
